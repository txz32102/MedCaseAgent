OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://zxmmm.com/v1
OPENAI_MODEL=qwen3.6-plus

# Reasoning effort controls model latency/cost vs. deliberation.
# Accepted: none, minimal, low, medium, high, xhigh.
# Aliases: med/mid=medium, max/maximum/x-high/extra_high=xhigh.
# For routine runs use low or medium; use high/xhigh only for difficult cases.
OPENAI_REASONING_EFFORT=low

MEDCASE_OUTPUT_DIR=runs
MEDCASE_ENABLE_TOOLS=true
MEDCASE_MAX_TOOL_TURNS=8
MEDCASE_CURATE_CITATIONS=true
MEDCASE_TARGET_REFERENCES=10
